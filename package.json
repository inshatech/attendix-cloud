{
  "name": "attendix-cloud",
  "version": "2.0.0",
  "description": "Attendix Cloud - Attendance and Payroll simplified",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\" --names \"api,ui\" --prefix-colors \"cyan,magenta\"",
    "client:dev": "npm run dev --prefix client",
    "client:build": "npm run build --prefix client",
    "server:dev": "node --watch server/app.js",
    "build": "npm run client:build",
    "start": "node server/app.js",
    "seed": "node server/scripts/seed-admin.js && node server/scripts/seed-plans.js",
    "seed:admin": "node server/scripts/seed-admin.js",
    "seed:plans": "node server/scripts/seed-plans.js",
    "check": "node server/setup-check.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "concurrently": "^9.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "nodemailer": "^6.9.7",
    "qrcode": "^1.5.3",
    "speakeasy": "^2.0.0",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "clsx": "^2.1.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "framer-motion": "^12.38.0",
    "globals": "^17.4.0",
    "lucide-react": "^0.577.0",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.1",
    "zustand": "^5.0.12"
  }
}